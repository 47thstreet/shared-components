---
/**
 * EventCard — Displays an event with image, date, venue, price, and ticket link.
 * Copy this file into your Astro project's src/components/ directory.
 * Requires Tailwind CSS.
 *
 * Usage:
 *   import EventCard from '../components/EventCard.astro';
 *   <EventCard
 *     name="Summer Rooftop"
 *     date="2026-07-15"
 *     time="10:00 PM"
 *     venue="Somewhere NYC"
 *     imageUrl="/flyer.jpg"
 *     ticketUrl="https://kartis-astro.vercel.app/en/event/summer-rooftop"
 *     price="$25"
 *     featured={true}
 *   />
 */

interface Props {
  name: string;
  date: string;
  time?: string;
  venue?: string;
  location?: string;
  imageUrl?: string;
  ticketUrl?: string;
  price?: string;
  featured?: boolean;
  accentColor?: string;
}

const {
  name,
  date,
  time,
  venue,
  location,
  imageUrl,
  ticketUrl,
  price,
  featured = false,
  accentColor = '#a78bfa',
} = Astro.props;

const d = new Date(date);
const dateStr = d.toLocaleDateString('en-US', { weekday: 'short', day: 'numeric', month: 'short' });
---

<div class="event-card group relative overflow-hidden bg-[#111] border border-white/[0.04] transition-all duration-400 hover:-translate-y-1 hover:border-white/[0.08] hover:shadow-[0_20px_60px_rgba(0,0,0,0.4)]">
  <!-- Image -->
  <div class="relative h-48 overflow-hidden bg-gradient-to-br from-purple-500/10 to-pink-500/10">
    {imageUrl ? (
      <img src={imageUrl} alt={name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="text-5xl opacity-30">🎶</span>
      </div>
    )}
    {featured && (
      <span class="absolute top-3 left-3 text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 bg-white/10 backdrop-blur-sm border border-white/20 text-white">
        Featured
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="text-lg font-semibold tracking-tight text-white mb-2 group-hover:text-white/90 transition-colors">
      {name}
    </h3>

    <div class="space-y-1.5 text-sm text-white/50">
      <div class="flex items-center gap-2">
        <span>📅</span>
        <span>{dateStr}{time ? ` · ${time}` : ''}</span>
      </div>
      {venue && (
        <div class="flex items-center gap-2">
          <span>📍</span>
          <span>{venue}{location ? `, ${location}` : ''}</span>
        </div>
      )}
      {price && (
        <div class="flex items-center gap-2">
          <span>💰</span>
          <span>{price}</span>
        </div>
      )}
    </div>

    {ticketUrl && (
      <a
        href={ticketUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-5 px-5 py-2.5 text-xs font-medium tracking-wider uppercase border transition-all duration-300 hover:-translate-y-0.5"
        style={`border-color: ${accentColor}; color: ${accentColor}`}
      >
        Get Tickets →
      </a>
    )}
  </div>
</div>
