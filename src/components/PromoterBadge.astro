---
/**
 * PromoterBadge — Displays a promoter's name, tier, and stats.
 * Copy this file into your Astro project's src/components/ directory.
 * Requires Tailwind CSS.
 *
 * Usage:
 *   import PromoterBadge from '../components/PromoterBadge.astro';
 *   <PromoterBadge name="Alex M." tier="gold" ticketsSold={142} />
 *   <PromoterBadge name="Sarah K." tier="platinum" ticketsSold={500} commission={0.20} avatarUrl="/avatars/sarah.jpg" />
 */

interface Props {
  name: string;
  tier?: 'bronze' | 'silver' | 'gold' | 'platinum';
  ticketsSold?: number;
  commission?: number;
  avatarUrl?: string;
  promoCode?: string;
  compact?: boolean;
}

const {
  name,
  tier = 'bronze',
  ticketsSold = 0,
  commission,
  avatarUrl,
  promoCode,
  compact = false,
} = Astro.props;

const tierConfig: Record<string, { color: string; label: string; icon: string }> = {
  bronze:   { color: '#cd7f32', label: 'Bronze',   icon: '🥉' },
  silver:   { color: '#c0c0c0', label: 'Silver',   icon: '🥈' },
  gold:     { color: '#ffd700', label: 'Gold',     icon: '🥇' },
  platinum: { color: '#e5e4e2', label: 'Platinum', icon: '💎' },
};

const t = tierConfig[tier];
const initials = name.split(' ').map(w => w[0]).join('').toUpperCase();
---

{compact ? (
  <!-- Compact inline badge -->
  <span
    class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium tracking-wide border bg-white/[0.03]"
    style={`border-color: ${t.color}; color: ${t.color}`}
  >
    <span>{t.icon}</span>
    <span>{name}</span>
    {ticketsSold > 0 && <span class="opacity-60">· {ticketsSold} sold</span>}
  </span>
) : (
  <!-- Full promoter card -->
  <div class="promoter-badge group p-5 bg-[#111] border border-white/[0.04] transition-all duration-300 hover:-translate-y-1 hover:border-white/[0.08] hover:shadow-[0_16px_48px_rgba(0,0,0,0.3)]">
    <div class="flex items-center gap-4">
      <!-- Avatar -->
      <div
        class="w-12 h-12 shrink-0 flex items-center justify-center border transition-colors"
        style={`border-color: ${t.color}`}
      >
        {avatarUrl ? (
          <img src={avatarUrl} alt={name} class="w-full h-full object-cover" />
        ) : (
          <span class="text-sm font-semibold" style={`color: ${t.color}`}>{initials}</span>
        )}
      </div>

      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <h4 class="text-sm font-medium text-white truncate">{name}</h4>
          <span
            class="text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 border"
            style={`border-color: ${t.color}; color: ${t.color}`}
          >
            {t.icon} {t.label}
          </span>
        </div>

        <div class="flex items-center gap-4 text-xs text-white/40">
          {ticketsSold > 0 && (
            <span>🎟️ {ticketsSold.toLocaleString()} sold</span>
          )}
          {commission !== undefined && (
            <span>💰 {(commission * 100).toFixed(0)}% commission</span>
          )}
          {promoCode && (
            <span class="font-mono text-white/30">code: {promoCode}</span>
          )}
        </div>
      </div>
    </div>
  </div>
)}
