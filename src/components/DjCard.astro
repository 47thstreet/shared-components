---
/**
 * DjCard — DJ profile card with name, photo, genres, and social links.
 * Copy this file into your Astro project's src/components/ directory.
 * Requires Tailwind CSS.
 *
 * @param {string} name - DJ/artist name (required)
 * @param {string} [photoUrl] - URL to the DJ's photo
 * @param {string[]} [genres] - Array of genre tags (e.g. ["House", "Techno"])
 * @param {string} [bio] - Short bio or tagline
 * @param {{ platform: string; url: string }[]} [socialLinks] - Social media links
 * @param {string} [accentColor] - Accent color for hover effects (default: #a78bfa)
 * @param {boolean} [compact] - Render a smaller inline version
 *
 * Usage:
 *   import DjCard from '../components/DjCard.astro';
 *   <DjCard
 *     name="DJ Aria"
 *     photoUrl="/djs/aria.jpg"
 *     genres={["House", "Afrobeats"]}
 *     bio="Resident DJ at FTRL"
 *     socialLinks={[
 *       { platform: "instagram", url: "https://instagram.com/djaria" },
 *       { platform: "soundcloud", url: "https://soundcloud.com/djaria" },
 *     ]}
 *   />
 */

interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  name: string;
  photoUrl?: string;
  genres?: string[];
  bio?: string;
  socialLinks?: SocialLink[];
  accentColor?: string;
  compact?: boolean;
}

const {
  name,
  photoUrl,
  genres = [],
  bio,
  socialLinks = [],
  accentColor = '#a78bfa',
  compact = false,
} = Astro.props;

const initials = name.split(' ').map(w => w[0]).join('').toUpperCase();

const platformIcons: Record<string, string> = {
  instagram: 'IG',
  soundcloud: 'SC',
  spotify: 'SP',
  twitter: 'TW',
  x: 'X',
  facebook: 'FB',
  youtube: 'YT',
  tiktok: 'TK',
  mixcloud: 'MX',
  bandcamp: 'BC',
};
---

{compact ? (
  <div class="inline-flex items-center gap-3 px-4 py-2.5 bg-[#111] border border-white/[0.04] transition-all duration-300 hover:border-white/[0.08]">
    <div
      class="w-8 h-8 shrink-0 flex items-center justify-center border overflow-hidden"
      style={`border-color: ${accentColor}`}
    >
      {photoUrl ? (
        <img src={photoUrl} alt={name} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <span class="text-[10px] font-bold" style={`color: ${accentColor}`}>{initials}</span>
      )}
    </div>
    <span class="text-sm font-medium text-white">{name}</span>
    {genres.length > 0 && (
      <span class="text-xs text-white/30">{genres.slice(0, 2).join(' / ')}</span>
    )}
  </div>
) : (
  <div class="dj-card group relative overflow-hidden bg-[#111] border border-white/[0.04] transition-all duration-400 hover:-translate-y-1 hover:border-white/[0.08] hover:shadow-[0_20px_60px_rgba(0,0,0,0.4)]">
    {/* Photo */}
    <div class="relative h-56 overflow-hidden bg-gradient-to-br from-purple-500/10 to-pink-500/10">
      {photoUrl ? (
        <img src={photoUrl} alt={name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      ) : (
        <div class="w-full h-full flex items-center justify-center">
          <span class="text-4xl font-black text-white/10">{initials}</span>
        </div>
      )}
      {/* Gradient overlay */}
      <div class="absolute inset-0 bg-gradient-to-t from-[#111] via-transparent to-transparent opacity-80" />
    </div>

    {/* Content */}
    <div class="p-6 -mt-8 relative z-10">
      <h3 class="text-lg font-semibold tracking-tight text-white mb-1 group-hover:text-white/90 transition-colors">
        {name}
      </h3>

      {bio && (
        <p class="text-sm text-white/40 mb-3 line-clamp-2">{bio}</p>
      )}

      {genres.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {genres.map((genre) => (
            <span
              class="text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 border bg-white/[0.03]"
              style={`border-color: color-mix(in srgb, ${accentColor} 40%, transparent); color: ${accentColor}`}
            >
              {genre}
            </span>
          ))}
        </div>
      )}

      {socialLinks.length > 0 && (
        <div class="flex items-center gap-2 pt-2 border-t border-white/[0.06]">
          {socialLinks.map(({ platform, url }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[10px] font-bold tracking-wider uppercase px-2.5 py-1.5 text-white/40 border border-white/[0.06] transition-all duration-300 hover:text-white hover:border-white/20 hover:bg-white/[0.05]"
              title={platform}
            >
              {platformIcons[platform.toLowerCase()] || platform.slice(0, 2).toUpperCase()}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
)}
