---
/**
 * CountdownTimer — A live countdown to a target date/time.
 * Copy this file into your Astro project's src/components/ directory.
 * Requires Tailwind CSS. Works with vanilla JS (no React/Vue needed).
 *
 * Usage:
 *   import CountdownTimer from '../components/CountdownTimer.astro';
 *   <CountdownTimer targetDate="2026-07-15T22:00:00" />
 *   <CountdownTimer targetDate="2026-12-31T00:00:00" label="New Year's Eve" expiredText="Happy New Year!" accentColor="#00d4ff" />
 */

interface Props {
  targetDate: string;
  label?: string;
  expiredText?: string;
  accentColor?: string;
  compact?: boolean;
}

const {
  targetDate,
  label,
  expiredText = 'Event has started!',
  accentColor = '#a78bfa',
  compact = false,
} = Astro.props;

const uid = `cd-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class="countdown-timer"
  id={uid}
  data-target={targetDate}
  data-expired-text={expiredText}
  data-compact={compact.toString()}
>
  {label && (
    <p class="text-xs tracking-[0.2em] uppercase text-white/40 mb-4 text-center">{label}</p>
  )}

  <div class={`flex items-center justify-center ${compact ? 'gap-3' : 'gap-4 sm:gap-6'}`}>
    {['days', 'hours', 'minutes', 'seconds'].map((unit) => (
      <div class="flex flex-col items-center">
        <div
          class={`flex items-center justify-center border border-white/[0.1] bg-white/[0.05] backdrop-blur-sm ${compact ? 'h-10 w-10 rounded-lg' : 'h-16 w-16 sm:h-20 sm:w-20 rounded-xl'}`}
          style={`border-color: color-mix(in srgb, ${accentColor} 30%, transparent)`}
        >
          <span
            class={`font-black tabular-nums tracking-tight ${compact ? 'text-base' : 'text-2xl sm:text-3xl'}`}
            data-unit={unit}
          >
            --
          </span>
        </div>
        <span
          class={`mt-2 font-bold uppercase tracking-[0.2em] text-white/30 ${compact ? 'text-[8px]' : 'text-[10px]'}`}
        >
          {unit.slice(0, compact ? 1 : undefined)}
        </span>
      </div>
    ))}
  </div>

  <div class="countdown-expired hidden text-center mt-4">
    <span class="text-sm font-medium" style={`color: ${accentColor}`}></span>
  </div>
</div>

<script>
  document.querySelectorAll('.countdown-timer').forEach((el) => {
    const target = new Date(el.getAttribute('data-target') || '').getTime();
    const expiredText = el.getAttribute('data-expired-text') || 'Event has started!';
    const expiredEl = el.querySelector('.countdown-expired span');
    const units = {
      days: el.querySelector('[data-unit="days"]'),
      hours: el.querySelector('[data-unit="hours"]'),
      minutes: el.querySelector('[data-unit="minutes"]'),
      seconds: el.querySelector('[data-unit="seconds"]'),
    };

    function update() {
      const diff = target - Date.now();
      if (diff <= 0) {
        Object.values(units).forEach((u) => { if (u) u.textContent = '00'; });
        const expired = el.querySelector('.countdown-expired');
        if (expired) expired.classList.remove('hidden');
        if (expiredEl) expiredEl.textContent = expiredText;
        return false;
      }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff / 3600000) % 24);
      const m = Math.floor((diff / 60000) % 60);
      const s = Math.floor((diff / 1000) % 60);
      if (units.days) units.days.textContent = String(d).padStart(2, '0');
      if (units.hours) units.hours.textContent = String(h).padStart(2, '0');
      if (units.minutes) units.minutes.textContent = String(m).padStart(2, '0');
      if (units.seconds) units.seconds.textContent = String(s).padStart(2, '0');
      return true;
    }

    if (update()) {
      const interval = setInterval(() => {
        if (!update()) clearInterval(interval);
      }, 1000);
    }
  });
</script>
